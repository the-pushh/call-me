# =========================================
# Monorepo .gitignore — Next.js + FastAPI
# =========================================

# ---------- Next.js / Node ----------
**/node_modules/
**/.next/
**/out/
**/.turbo/
**/dist/
**/build/

# Next.js cache & generated files
**/.vercel
**/next-env.d.ts
**/*.tsbuildinfo

# Env files (Node side)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Debug logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Testing
**/coverage/

# Planning / generated files
**/planning/

# ---------- Python / FastAPI ----------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
**/venv/
**/.venv/
**/env/
**/ENV/

# Distribution / packaging
**/build/
**/dist/
**/*.egg-info/
**/*.egg

# Env files (Python side)
**/.env
**/.env.*
!**/.env.example

# Caches
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.cache

# Database files (common in FastAPI dev setups)
**/*.sqlite3
**/*.db

# ---------- Editors / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------- Logs ----------
**/*.log

# ---------- Misc ----------
*.pem
.env.vault

# post-call visitor remarks (local data)
backend/feedback.jsonl
